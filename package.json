{
  "name": "ado-copilot-code-review-ang031",
  "version": "0.1.2",
  "description": "Azure DevOps extension for automated code reviews using GitHub Copilot",
  "scripts": {
    "build": "cd CopilotCodeReviewV1 && npm run build",
    "build:dev": "cd CopilotCodeReviewDevV1 && npm run build",
    "package:prod": "tfx extension create --manifest-globs vss-extension.json",
    "package:dev": "pwsh -File build-dev.ps1",
    "test:pwsh": "pwsh -NoProfile -Command \"Invoke-Pester -Path CopilotCodeReviewV1/scripts/tests -Output Detailed\"",
    "test:ts": "cd CopilotCodeReviewV1 && npm run test:ts",
    "test": "npm run test:ts && npm run test:pwsh",
    "bump": "node scripts/bump-version.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MakeMake23/ado-copilot-code-review.git"
  },
  "keywords": [
    "azure-devops",
    "copilot",
    "code-review",
    "pull-request",
    "ai"
  ],
  "author": "ANG031-Diyar",
  "license": "GPL-3.0"
}
